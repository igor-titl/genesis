---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div id="canvas-container">
    <canvas id="neural-canvas"></canvas>
  </div>
</Layout>

<style>
  #canvas-container {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #01020a;
  }

  #neural-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script src="../scripts/neural-canvas.js"></script>
